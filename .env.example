# ================================
# 微信账号与基础路径
# ================================

# 微信账号根目录。
# 必填。通常指向 xwechat_files 下的某个账号目录。
WECHAT_ROOT=/path/to/xwechat_files/<account_id>

# 当前账号自己的 wxid。
# 画像分析必填；聊天导出时也会用于给“我”的消息补全 wxid。
WXID=wxid_xxx

# 解密后数据库所在目录。
# 可选。未单独覆盖具体数据库路径时，会从这里拼出默认值。
DECRYPTED_DB_DIR=data/db/dec

# 统一导出根目录。
# 可选。CSV、媒体文件、messages.db 都会默认输出到这里。
EXPORT_DIR=data/out


# ================================
# 导出与画像任务参数
# 当前示例仅保留与任务本身强相关的参数；
# 具体如何触发导出或画像流程，后续由程序入口统一调整。
# ================================

# 画像分析输出的 SQLite 文件路径。
# 可选。默认输出到 ${EXPORT_DIR}/db/messages.db。
PROFILE_OUTPUT_PATH=

# 画像分析时每多少条消息切一片喂给 AI。
# 可选。默认 500。
PROFILE_SLICE_SIZE=500

# 聊天导出输出的 SQLite 文件路径。
# 可选。默认输出到 ${EXPORT_DIR}/db/messages.db。
EXPORT_OUTPUT_PATH=


# ================================
# AI 配置
# 只做聊天导出时，AI 是可选的；若需要媒体备注或画像分析，则需要配置。
# ================================

# OpenAI API Key。
# 可选。配置后可用于图片理解、对话总结等。
OPENAI_API_KEY=

# Google / Gemini API Key。
# 可选。配置后可用于聊天、图片、音频转写等。
GOOGLE_API_KEY=

# 导出阶段图片备注所用模型，格式：平台:模型。
# 例如 OPENAI:gpt-4o-mini 或 GOOGLE:gemini-2.5-flash。
AI_IMAGE_MODEL=OPENAI:gpt-4o-mini

# 导出阶段视频封面/抽帧备注所用模型，格式同上。
AI_VIDEO_MODEL=OPENAI:gpt-4o-mini

# 导出阶段语音转写/语音备注所用模型，格式同上。
AI_AUDIO_MODEL=GOOGLE:gemini-2.5-flash

# 画像分析所用聊天模型，格式同上。
AI_PROFILE_MODEL=OPENAI:gpt-4o-mini

# Google 聊天模型默认值覆盖。
# 可选。仅在使用 GOOGLE/GEMINI 且未在 model spec 中显式指定时生效。
GOOGLE_CHAT_MODEL=gemini-2.5-flash

# Google 视觉模型默认值覆盖。
# 可选。仅在使用 GOOGLE/GEMINI 且未在 model spec 中显式指定时生效。
GOOGLE_VISION_MODEL=gemini-2.5-flash


# ================================
# 数据库路径
# 不填时会基于 DECRYPTED_DB_DIR 使用默认文件名。
# ================================

# 微信消息数据库。
MESSAGE_DB_PATH=data/db/dec/message_0.db

# 微信消息资源数据库。
# 图片、视频等媒体定位会用到。
MESSAGE_RESOURCE_DB_PATH=data/db/dec/message_resource.db

# 微信媒体数据库。
# 语音导出会用到。
MEDIA_DB_PATH=data/db/dec/media_0.db

# 微信 hardlink 数据库。
# 图片、视频素材定位会用到。
HARDLINK_DB_PATH=data/db/dec/hardlink.db

# 微信联系人数据库。
CONTACT_DB_PATH=data/db/dec/contact.db

# 微信表情数据库。
# 仅表情解析相关逻辑会用到。
EMOTICON_DB_PATH=data/db/dec/emoticon.db


# ================================
# 多媒体解密 / 数据库探测
# 只在图片 .dat 恢复、数据库解密探测等场景下使用。
# ================================

# 图片 .dat 恢复使用的 32 位 ASCII key。
KEY32=0123456789abcdef0123456789abcdef

# SQLCipher 探测时使用的抓包 salt，16 字节十六进制。
CAPTURED_SALT=00112233445566778899aabbccddeeff

# SQLCipher 探测密码前半段，十六进制字符串。
PASSWORD_1=00112233445566778899aabbccddeeff

# SQLCipher 探测密码后半段，十六进制字符串。
PASSWORD_2=00112233445566778899aabbccddeeff
