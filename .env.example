# 微信账号根目录
WECHAT_ROOT=/path/to/xwechat_files/<account_id>

# 图片 .dat 恢复使用的 32 位 ASCII key
KEY32=0123456789abcdef0123456789abcdef

# SQLCipher 数据库解密参数
CAPTURED_SALT=00112233445566778899aabbccddeeff
PASSWORD_1=00112233445566778899aabbccddeeff
PASSWORD_2=00112233445566778899aabbccddeeff

# 可选：统一指定解密后数据库目录
DECRYPTED_DB_DIR=data/db/dec

# 可选：单独覆盖数据库路径
MESSAGE_DB_PATH=data/db/dec/message_0.db
MESSAGE_RESOURCE_DB_PATH=data/db/dec/message_resource.db
MEDIA_DB_PATH=data/db/dec/media_0.db
HARDLINK_DB_PATH=data/db/dec/hardlink.db
CONTACT_DB_PATH=data/db/dec/contact.db

# 可选：数据库抓取输出目录
DB_CAPTURE_OUTPUT_DIR=data/db

# 可选：CSV 导出默认参数
CSV_CONTACT_NAME_KEYWORD=第一
CSV_OUTPUT_PATH=data/out/messages.csv

# 可选：演示入口默认参数
DEMO_MSG_TABLE=Msg_xxx
DEMO_LOCAL_ID=1
DEMO_OUTPUT_DIR=data/msg/video
